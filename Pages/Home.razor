@page "/"
@inject HttpClient Http
@using System.Net.Http.Json

<PageTitle>Kelly | Full-Stack Developer</PageTitle>

<div class="section">
    <div class="container text-center">
        <img src="assets/picture.png" alt="Profile Picture" class="profile-pic mb-4" />
        <h1 class="mb-3 hero-animate" style="font-size: 3.5rem; font-weight: 800; letter-spacing: -1px;">Hello, I'm
            <span class="dot">Kelly</span>
        </h1>
        <h2 class="h4 text-muted mb-4 hero-animate">Full-Stack Developer & Technical Philologist</h2>
        <p class="mb-4 hero-animate" style="max-width: 750px; margin: 0 auto; font-size: 1.15rem; line-height: 1.8;">
            I am a 1st-year Philology student and a passionate developer with a deep interest in linguistics. As a
            "Technical Philologist", I effectively blend my humanities background - including winning multiple English
            Olympiads and tutoring peers in advanced grammar - with a solid foundation in Web Technologies, Python, and
            C#. I actively use my analytical mindset to solve complex structural problems, whether in code or language.
        </p>
    </div>
</div>
<div class="section"
    style="background-color: var(--secondary-color); border-top: 1px solid var(--card-border); border-bottom: 1px solid var(--card-border);">
    <div class="container">
        <h3 class="mb-4 text-center">Skills & Experience</h3>
        <div class="card-grid">
            <div class="card">
                <h4 class="card-title">Core Technologies</h4>
                <div class="mt-2">
                    <span class="tag">C# / .NET</span>
                    <span class="tag">Python</span>
                    <span class="tag">HTML/CSS/JS</span>
                    <span class="tag">Lua</span>
                    <span class="tag">Blazor WebAssembly</span>
                    <span class="tag">Git</span>
                    <span class="tag">Linux</span>
                </div>
            </div>
            <div class="card">
                <h4 class="card-title">Soft Skills</h4>
                <div class="mt-2 text-muted">
                    <ul style="padding-left: 1.2rem; margin:0; line-height: 1.8;">
                        <li>Punctuality & Responsibility</li>
                        <li>Team Collaboration</li>
                        <li>Analytical Thinking</li>
                        <li>Adaptability & Fast Learner</li>
                    </ul>
                </div>
            </div>
            <div class="card">
                <h4 class="card-title">Philology & Extras</h4>
                <div class="mt-2 text-muted">
                    <ul style="padding-left: 1.2rem; margin:0; line-height: 1.8;">
                        <li><strong>English</strong> - B1/B2 (Upper-Intermediate, Olympiad Winner)</li>
                        <li><strong>Ukrainian</strong> - Native</li>
                        <li>Advanced Grammar & Language Tutor</li>
                        <li>Hardware Enthusiast & PC Power-User</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="section" style="border-bottom: 1px solid var(--card-border);">
    <div class="container">
        <h3 class="mb-5 text-center">GitHub Stats & Activity</h3>
        <div class="stats-grid"
            style="display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 2rem; align-items: start;">

            <div style="display:flex; flex-direction:column; gap:1.5rem;">
                <!-- GitHub Top Languages & User Stats -->
                <div class="card p-0"
                    style="padding: 1rem; display: flex; align-items: center; justify-content: center;">
                    <img src="https://raw.githubusercontent.com/malichevsky/malichevsky/main/profile/stats.svg?v=2"
                        alt="GitHub Stats" style="width: 100%; max-width: 420px;" />
                </div>
                <div class="card p-0"
                    style="padding: 1rem; display: flex; align-items: center; justify-content: center;">
                    <img src="https://raw.githubusercontent.com/malichevsky/malichevsky/main/profile/top-langs.svg?v=2"
                        alt="Top Languages" style="width: 100%; max-width: 420px;" />
                </div>
                <div class="card p-0"
                    style="padding: 1rem; display: flex; align-items: center; justify-content: center;">
                    <img src="https://streak-stats.demolab.com/?user=malichevsky&theme=transparent&hide_border=true&ring=3b82f6&fire=3b82f6&currStreakNum=f3f4f6&sideNums=f3f4f6&dates=8f939e&labels=8f939e&stroke=00000000"
                        alt="GitHub Streak" style="width: 100%; max-width: 420px;" />
                </div>
            </div>

            <div style="display:flex; align-items:stretch;">
                <!-- WakaTime Metrics -->
                <div class="card"
                    style="width: 100%; display: flex; align-items: center; justify-content: center; padding: 1.5rem;">
                    <img src="https://raw.githubusercontent.com/malichevsky/malichevsky/main/profile/wakatime.svg?v=1"
                        alt="WakaTime Activity" style="width: 100%; max-width: 500px;" />
                </div>
            </div>

        </div>
    </div>
</div>

<div class="section">
    <div class="container">
        <h3 class="mb-5 text-center">Featured Projects</h3>

        @if (repositories == null)































































        {
            <div class="text-center mt-5 text-muted">
                <p>Fetching projects from GitHub...</p>
            </div>
        }































































        else if (loadError)































































        {
            <div class="text-center mt-5">
                <p style="color: #ff4444;">Failed to load projects from GitHub. Please visit my <a
                        href="https://github.com/malichevsky" target="_blank" style="color: var(--primary-color);">GitHub
                        profile</a>.</p>
            </div>
        }































































        else































































        {
            <div class="card-grid">
                @foreach (var repo in repositories)































































                {
                    <a href="@repo.html_url" target="_blank" class="card" style="text-decoration: none; color: inherit;">
                        <h4 class="card-title" style="color: var(--primary-color);">@repo.name</h4>
                        <p class="card-text">@(string.IsNullOrEmpty(repo.description) ? "No description available." :
                    repo.description)</p>
                        <div
                            style="display: flex; justify-content: space-between; font-size: 0.9em; color: var(--text-muted); font-weight: 500;">
                            <span>@(repo.language ?? "Mixed")</span>
                            <span>⭐ @repo.stargazers_count</span>
                        </div>
                    </a>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<GitHubRepo>? repositories;































































    private bool loadError = false;































































































































    protected override async Task OnInitializedAsync()































































    {































































        try































































        {































































            var request = new HttpRequestMessage(HttpMethod.Get,































            "https://api.github.com/users/malichevsky/repos?sort=updated&per_page=10");































































            request.Headers.Add("User-Agent", "Blazor-Portfolio");































































































































            var response = await Http.SendAsync(request);































































































































            if (response.IsSuccessStatusCode)































































            {































































                var repos = await response.Content.ReadFromJsonAsync<List<GitHubRepo>>();































































                if (repos != null)































































                {































































                    // Filter out forks and get top 6 by stars to highlight best repos































































                    repositories = repos.Where(r => !r.fork)































































                    .OrderByDescending(r => r.stargazers_count)































































                    .Take(6)































































                    .ToList();































































                }































































            }































































            else































































            {































































                loadError = true;































































            }































































        }































































        catch (Exception)































































        {































































            loadError = true;































































        }































































    }































































































































    public class GitHubRepo































































    {































































        public string name { get; set; } = "";































































        public string? description { get; set; }































































        public string html_url { get; set; } = "";































































        public string? language { get; set; }































































        public int stargazers_count { get; set; }































































        public bool fork { get; set; }































































    }
}
